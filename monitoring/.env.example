# Monitoring Stack Environment Variables
# Optimizado para Hetzner CPX31 (8GB RAM)

# Grafana Configuration
GRAFANA_ADMIN_PASSWORD=changeme_in_production_strong_password_here
GRAFANA_ADMIN_USER=admin

# Database Configuration (for exporters)
DB_USER=predix
DB_PASSWORD=your_db_password_here
DB_NAME=predix_db

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here

# Alert Manager Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL=alerts@yourcompany.com

# Prometheus Configuration
PROMETHEUS_RETENTION_DAYS=15

# General
ENVIRONMENT=production
CLUSTER_NAME=predix-hetzner
