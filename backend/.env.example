# ==========================================
# Predix Backend - Environment Variables
# ==========================================
# Copy this file to .env and fill in all values

# Application
ENVIRONMENT=development
SECRET_KEY=predix-super-secret-change-this-in-production-2024

# Database
DATABASE_URL=postgresql://predix_user:predix_pass@localhost:5432/predix_db
REDIS_URL=redis://localhost:6379/0

# ---- AI INTEGRATIONS ----
# Google Gemini (REQUIRED for Chat, Radar, and Community Manager features)
GEMINI_API_KEY=your_gemini_api_key_here

# ---- GOOGLE OAUTH & CALENDAR ----
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ---- SOCIAL MEDIA APIs ----
# Spotify (for Music Trends)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# YouTube (for YouTube Trends)
YOUTUBE_API_KEY=your_youtube_api_key

# Meta / Instagram (for IG Business Trends)
META_ACCESS_TOKEN=your_meta_access_token

# ---- PAYMENTS ----
# Paymentez (for LATAM payments)
PAYMENTEZ_APP_CODE=your_paymentez_app_code
PAYMENTEZ_APP_KEY=your_paymentez_app_key
PAYMENTEZ_ENVIRONMENT=stg
PAYMENTEZ_WEBHOOK_SECRET=your_webhook_secret

# ---- EMAIL ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# ---- MONITORING (Optional) ----
SENTRY_DSN=

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
