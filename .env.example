# Predix PWA - Variables de Entorno

# API Configuration
REACT_APP_API_URL=https://api.predix.app
REACT_APP_WS_URL=wss://ws.predix.app

# Environment
REACT_APP_ENVIRONMENT=development
REACT_APP_VERSION=1.0.0

# Features
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_OFFLINE=true

# External Services
REACT_APP_SENTRY_DSN=your_sentry_dsn_here
REACT_APP_GA_TRACKING_ID=your_ga_tracking_id_here

# PWA Configuration
REACT_APP_PWA_NAME=Predix
REACT_APP_PWA_SHORT_NAME=Predix
REACT_APP_PWA_DESCRIPTION=Plataforma predictiva de tendencias digitales con IA

# Development
REACT_APP_DEBUG=false
REACT_APP_MOCK_DATA=true
